{
  "build": {
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "node -e \"\""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pandoc Preview",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "label": "main"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default",
        {
          "identifier": "e2e-playwright",
          "description": "Tauri Playwright socket bridge for real desktop E2E proofs.",
          "windows": [
            "main"
          ],
          "permissions": [
            "playwright:default"
          ]
        }
      ]
    }
  }
}
